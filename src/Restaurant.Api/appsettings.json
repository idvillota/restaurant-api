{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=restaurantdb;Username=restaurantuser;Password=CHANGE_ME"
  },
  "Jwt": {
    "Issuer": "RestaurantManagement",
    "Audience": "RestaurantClients",
    "SigningKey": "CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "AccessTokenMinutes": 120
  },
  "Cors": {
    "Origins": [ "http://localhost:5173" ]
  },
  "ProductImages": {
    "RootPath": "uploads/products",
    "PublicBasePath": "/media/products",
    "MaxBytes": 5242880,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp", ".gif" ]
  }
}
